{
  "name": "ApprovedStaff",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "description": "\u05d0\u05d9\u05de\u05d9\u05d9\u05dc Google \u05de\u05d0\u05d5\u05e9\u05e8 \u05dc\u05db\u05e0\u05d9\u05e1\u05ea \u05d0\u05d9\u05e9 \u05e6\u05d5\u05d5\u05ea"
    },
    "full_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05de\u05dc\u05d0"
    },
