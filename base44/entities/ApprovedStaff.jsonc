    "activated_user_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05d4\u05ea\u05d7\u05d1\u05e8 \u05d1\u05e4\u05d5\u05e2\u05dc"
    },
    "activated_at": {
      "type": "string",
      "description": "\u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05ea\u05d7\u05d1\u05e8\u05d5\u05ea \u05e8\u05d0\u05e9\u05d5\u05e0\u05d4"
