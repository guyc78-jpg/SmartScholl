                {
                  "data.grade": {
                    "$in": [
                      "\u05d6",
                      "\u05d7",
                      "\u05d8"
                    ]
                  }
                }
              ]
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "grade_coordinator"
                  }
                },
                {
                  "data.grade": "{{user.data.authorization_grade}}"
                }
              ]
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "coordinator"
                  }
                },
                {
                  "data.grade": "{{user.data.authorization_grade}}"
