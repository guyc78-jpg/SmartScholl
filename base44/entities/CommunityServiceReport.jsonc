        "\u05de\u05de\u05ea\u05d9\u05df \u05dc\u05d0\u05d9\u05e9\u05d5\u05e8",
        "\u05d0\u05d5\u05e9\u05e8",
        "\u05d3\u05d5\u05e8\u05e9 \u05ea\u05d9\u05e7\u05d5\u05df",
        "\u05e0\u05d3\u05d7\u05d4"
      ],
      "default": "\u05de\u05de\u05ea\u05d9\u05df \u05dc\u05d0\u05d9\u05e9\u05d5\u05e8",
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05d3\u05d9\u05d5\u05d5\u05d7",
      "rls": {
        "create": {
          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
            {
              "user_condition": {
                "role": "system_admin"
              }
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "division_manager",
                    "authorization_division": "upper"
                  }
                },
                {
                  "data.grade": {
                    "$in": [
                      "\u05d9",
                      "\u05d9\u05d0",
                      "\u05d9\u05d1"
                    ]
                  }
                }
              ]
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "division_manager",
                    "authorization_division": "middle"
                  }
                },
                {
                  "data.grade": {
                    "$in": [
                      "\u05d6",
                      "\u05d7",
                      "\u05d8"
                    ]
                  }
                }
              ]
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "grade_coordinator"
                  }
                },
                {
                  "data.grade": "{{user.data.authorization_grade}}"
                }
              ]
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "coordinator"
                  }
                },
                {
                  "data.grade": "{{user.data.authorization_grade}}"
                }
              ]
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "homeroom_teacher"
                  }
                },
                {
                  "data.class_id": "{{user.data.authorization_class_id}}"
                }
              ]
            },
            {
              "$and": [
                {
                  "user_condition": {
                    "role": "student"
                  }
                },
                {
                  "data.status": "\u05de\u05de\u05ea\u05d9\u05df \u05dc\u05d0\u05d9\u05e9\u05d5\u05e8"
                }
              ]
            }
          ]
        },
