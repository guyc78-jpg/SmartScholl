{
  "name": "ScheduledConversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "\u05db\u05d5\u05ea\u05e8\u05ea \u05d4\u05e9\u05d9\u05d7\u05d4"
    },
    "conversation_type": {
      "type": "string",
      "enum": [
        "\u05e9\u05d9\u05d7\u05d4 \u05d0\u05d9\u05e9\u05d9\u05ea \u05e2\u05dd \u05ea\u05dc\u05de\u05d9\u05d3",
        "\u05e9\u05d9\u05d7\u05ea \u05d4\u05d5\u05e8\u05d9\u05dd",
        "\u05e4\u05d2\u05d9\u05e9\u05d4 \u05d8\u05d9\u05e4\u05d5\u05dc\u05d9\u05ea",
        "\u05ea\u05d6\u05db\u05d5\u05e8\u05ea \u05d8\u05d9\u05e4\u05d5\u05dc\u05d9\u05ea"
      ],
      "default": "\u05e9\u05d9\u05d7\u05ea \u05d4\u05d5\u05e8\u05d9\u05dd",
      "description": "\u05e1\u05d5\u05d2 \u05d4\u05e9\u05d9\u05d7\u05d4"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "\u05ea\u05d0\u05e8\u05d9\u05da \u05d4\u05e9\u05d9\u05d7\u05d4"
    },
    "time": {
      "type": "string",
      "description": "\u05e9\u05e2\u05ea \u05d4\u05e9\u05d9\u05d7\u05d4 (HH:MM)"
    },
    "student_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05ea\u05dc\u05de\u05d9\u05d3/\u05d4"
    },
    "student_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05ea\u05dc\u05de\u05d9\u05d3/\u05d4"
    },
    "class_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05db\u05d9\u05ea\u05d4"
    },
    "participants": {
      "type": "string",
      "description": "\u05de\u05e9\u05ea\u05ea\u05e4\u05d9\u05dd \u05d1\u05e9\u05d9\u05d7\u05d4"
    },
    "notes": {
      "type": "string",
      "description": "\u05d4\u05e2\u05e8\u05d5\u05ea"
    },
    "owner_user_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05d9\u05d6\u05dd \u05d0\u05ea \u05d4\u05e9\u05d9\u05d7\u05d4"
    },
    "owner_email": {
      "type": "string",
      "description": "\u05de\u05d9\u05d9\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05d9\u05d6\u05dd \u05d0\u05ea \u05d4\u05e9\u05d9\u05d7\u05d4"
    },
    "status": {
      "type": "string",
      "enum": [
        "\u05de\u05ea\u05d5\u05db\u05e0\u05e0\u05ea",
        "\u05d1\u05d5\u05e6\u05e2\u05d4",
        "\u05d1\u05d5\u05d8\u05dc\u05d4"
      ],
      "default": "\u05de\u05ea\u05d5\u05db\u05e0\u05e0\u05ea",
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05d4\u05e9\u05d9\u05d7\u05d4"
    },
    "reminder_sent": {
      "type": "boolean",
      "default": false,
      "description": "\u05d4\u05d0\u05dd \u05e0\u05e9\u05dc\u05d7\u05d4 \u05ea\u05d6\u05db\u05d5\u05e8\u05ea \u05e4\u05d5\u05e9"
    },
    "reminder_for_datetime": {
      "type": "string",
      "description": "\u05d4\u05de\u05d5\u05e2\u05d3 (ISO) \u05e9\u05e2\u05d1\u05d5\u05e8\u05d5 \u05e0\u05e9\u05dc\u05d7\u05d4 \u05d4\u05ea\u05d6\u05db\u05d5\u05e8\u05ea \u2014 \u05dc\u05d6\u05d9\u05d4\u05d5\u05d9 \u05e2\u05d3\u05db\u05d5\u05df \u05e9\u05de\u05d7\u05d9\u05d9\u05d1 \u05ea\u05d6\u05db\u05d5\u05e8\u05ea \u05de\u05d7\u05d3\u05e9"
    },
    "overdue_notified": {
      "type": "boolean",
      "default": false,
      "description": "\u05d4\u05d0\u05dd \u05e0\u05e9\u05dc\u05d7\u05d4 \u05d4\u05ea\u05e8\u05d0\u05d4 \u05e2\u05dc \u05e9\u05d9\u05d7\u05d4 \u05e9\u05dc\u05d0 \u05d8\u05d5\u05e4\u05dc\u05d4 \u05d1\u05d6\u05de\u05df"
    }
  },
  "required": [
    "title",
    "conversation_type",
    "date",
    "time"
  ]
}